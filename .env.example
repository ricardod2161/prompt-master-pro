# ─────────────────────────────────────────────────────────────────────────────
# GastroHub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
# Project URL — found in Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon/public key — safe to expose in the browser (RLS protects the data)
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>

# Project ID (used by CLI and edge functions)
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# ── Evolution API — WhatsApp integration (optional) ───────────────────────────
# Base URL of your self-hosted Evolution API instance
EVOLUTION_API_URL=https://evolution.yourdomain.com
# Global API key configured in your Evolution instance
EVOLUTION_API_KEY=<your-evolution-api-key>

# ── ElevenLabs — text-to-speech for WhatsApp bot (optional) ──────────────────
ELEVENLABS_API_KEY=<your-elevenlabs-api-key>

# ── Stripe — subscription billing (optional) ─────────────────────────────────
# Secret key — only used server-side in Supabase Edge Functions
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret-key>
# Webhook signing secret — validate events from Stripe
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>
# Price IDs for each subscription tier
STRIPE_PRICE_STARTER=price_<starter-price-id>
STRIPE_PRICE_PROFESSIONAL=price_<professional-price-id>
STRIPE_PRICE_ENTERPRISE=price_<enterprise-price-id>
